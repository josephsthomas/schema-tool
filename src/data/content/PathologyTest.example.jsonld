{
  "@context": "https://schema.org",
  "@type": "PathologyTest",
  "name": "Pap Smear",
  "description": "A Pap smear is a test to screen for cervical cancer. A provider collects cells from your cervix and sends them to a lab where the cells are checked under a microscope for cancer or signs that they are abnormal.",
  "usedToDiagnose": [
    {
      "@type": "MedicalCondition",
      "name": "Cervical cancer"
    }
  ],
  "signDetected": {
    "@type": "MedicalSign",
    "name": "Abnormal cervical cells"
  },
  "usesDevice": [
    {
      "@type": "MedicalDevice",
      "name": "Speculum"
    },
    {
      "@type": "MedicalDevice",
      "name": "Soft brush or swab"
    }
  ]
}
