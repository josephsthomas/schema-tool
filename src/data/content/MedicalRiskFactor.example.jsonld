{
  "@context": "https://schema.org",
  "@type": "MedicalRiskFactor",
  "name": "Cigarette smoking",
  "increasesRiskOf": {
    "@type": "MedicalCondition",
    "name": "Cardiovascular disease",
    "description": "Smoking is a major cause of CVD, causing one in every four deaths from CVD. Smoking increases the risk for coronary heart disease by 2 to 4 times. Even people who smoke fewer than five cigarettes a day can have early signs of cardiovascular disease."
  }
}
