// Reference example — built from public data sourced from NIH MedlinePlus (https://medlineplus.gov/lab-tests/blood-glucose-test/) on 2026-05-05. Not for use in client deliverables. Generate your own markup using your content in the Generator.
{
  "@context": "https://schema.org",
  "@type": "MedicalTest",
  "name": "Blood Glucose Test",
  "description": "A blood glucose test measures the glucose levels in your blood. Glucose is a type of sugar. It is your body's main source of energy.",
  "usedToDiagnose": [
    {
      "@type": "MedicalCondition",
      "name": "Prediabetes"
    },
    {
      "@type": "MedicalCondition",
      "name": "Diabetes"
    },
    {
      "@type": "MedicalCondition",
      "name": "Hypoglycemia"
    }
  ],
  "signDetected": {
    "@type": "MedicalSign",
    "name": "Hyperglycemia"
  },
  "usesDevice": [
    {
      "@type": "MedicalDevice",
      "name": "Blood glucose meter"
    },
    {
      "@type": "MedicalDevice",
      "name": "Continuous glucose monitor (CGM)"
    }
  ]
}
