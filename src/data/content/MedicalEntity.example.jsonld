// Reference example — built from public data sourced from CDC
// (https://www.cdc.gov/flu/about/index.html) and NIH MedlinePlus
// (https://medlineplus.gov/influenza.html) on 2026-05-05.
// MedicalEntity is the abstract parent type; in production prefer a concrete
// subtype such as InfectiousDisease or MedicalCondition. This example shows
// the cross-cutting pattern only.
// Not for use in client deliverables. Generate your own markup using your
// content in the Generator.
{
  "@context": "https://schema.org",
  "@type": "MedicalEntity",
  "name": "Influenza",
  "alternateName": "Flu",
  "description": "Flu is a contagious respiratory illness caused by influenza viruses that infect tissues in the nose, throat, and sometimes the lungs.",
  "code": {
    "@type": "MedicalCode",
    "codingSystem": "ICD-10-CM",
    "codeValue": "J11.1"
  },
  "recognizingAuthority": {
    "@type": "Organization",
    "name": "Centers for Disease Control and Prevention",
    "url": "https://www.cdc.gov/flu/about/index.html"
  }
}
