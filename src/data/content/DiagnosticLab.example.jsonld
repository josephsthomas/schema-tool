{
  "@context": "https://schema.org",
  "@type": "DiagnosticLab",
  "name": "Community Clinical Laboratory",
  "description": "A clinical laboratory that checks samples of blood, urine, or body tissues; a technician or doctor analyzes the test samples to see if results fall within the normal range.",
  "availableTest": [
    {
      "@type": "MedicalTest",
      "name": "Blood test"
    },
    {
      "@type": "MedicalTest",
      "name": "Urinalysis"
    },
    {
      "@type": "MedicalTest",
      "name": "Pathology sample analysis"
    }
  ]
}
