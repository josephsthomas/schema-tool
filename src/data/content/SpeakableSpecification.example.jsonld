{
  "@context": "https://schema.org",
  "@type": "SpecialAnnouncement",
  "name": "2025 U.S. Measles Outbreak Update",
  "datePosted": "2026-01-15",
  "expires": "2026-12-31",
  "text": "A total of 2,288 confirmed measles cases were reported in the United States during 2025. The best way to protect yourself against measles is with the measles, mumps, and rubella (MMR) vaccine.",
