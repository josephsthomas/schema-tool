{
  "@context": "https://schema.org",
  "@type": "AnatomicalSystem",
  "name": "Vascular system",
  "description": "Your body's network of blood vessels.",
  "comprisedOf": [
    {
      "@type": "AnatomicalStructure",
      "name": "Arteries",
      "description": "Carry oxygen-rich blood from your heart to your tissues and organs."
    },
    {
      "@type": "AnatomicalStructure",
      "name": "Veins",
      "description": "Carry the blood and waste products back to your heart."
    },
    {
      "@type": "AnatomicalStructure",
      "name": "Capillaries",
      "description": "Tiny blood vessels that connect your small arteries to your small veins."
    }
  ],
  "relatedCondition": {
    "@type": "MedicalCondition",
    "name": "Aneurysm",
    "description": "A bulge or ballooning in the wall of an artery."
  }
}
