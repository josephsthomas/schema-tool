{
  "@context": "https://schema.org",
  "@type": "Physician",
  "name": "Primary Care Provider",
  "description": "A health care practitioner who sees people that have common medical problems, serving as the patient's main health care provider in non-emergency situations.",
  "availableService": [
    {
      "@type": "MedicalProcedure",
      "name": "Preventive care",
      "description": "Delivering preventive care and promoting healthy lifestyle choices."
    },
    {
      "@type": "MedicalProcedure",
      "name": "Diagnosis and treatment of routine medical conditions",
      "description": "Diagnosing and treating routine medical conditions, and evaluating the severity of health concerns."
    },
    {
      "@type": "MedicalProcedure",
      "name": "Specialist referral",
      "description": "Referring patients to specialists when medical or surgical expertise is needed."
    }
  ]
}
