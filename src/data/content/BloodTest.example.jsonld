// Reference example — built from public data sourced from NIH MedlinePlus (https://medlineplus.gov/lab-tests/complete-blood-count-cbc/) on 2026-05-05. Not for use in client deliverables. Generate your own markup using your content in the Generator.
{
  "@context": "https://schema.org",
  "@type": "BloodTest",
  "name": "Complete Blood Count (CBC)",
  "description": "A complete blood count, or CBC, is a group of blood tests that measure the number and size of the different cells in your blood.",
  "usedToDiagnose": [
    {
      "@type": "MedicalCondition",
      "name": "Anemia"
    },
    {
      "@type": "MedicalCondition",
      "name": "Blood cancers"
    },
    {
      "@type": "MedicalCondition",
      "name": "Immune system disorders"
    },
    {
      "@type": "MedicalCondition",
      "name": "Infections"
    }
  ],
  "subTest": [
    { "@type": "BloodTest", "name": "Red blood cell count" },
    { "@type": "BloodTest", "name": "White blood cell count" },
    { "@type": "BloodTest", "name": "Platelet count" },
    { "@type": "BloodTest", "name": "Hemoglobin" },
    { "@type": "BloodTest", "name": "Hematocrit" },
    { "@type": "BloodTest", "name": "Mean corpuscular volume (MCV)" }
  ]
}
