//
// Note: MedlinePlus describes Medicare Part D as prescription drug coverage
// that helps pay for some medicines. Drug-tier values, mail-order availability,
// and per-tier cost sharing are plan-specific and should be filled in from your
// own verified plan documents.
{
  "@context": "https://schema.org",
  "@type": "HealthPlanFormulary",
  "name": "Medicare Part D drug coverage",
  "description": "Part D is prescription drug coverage. It helps pay for some medicines."
}
