// Reference example — built from public data sourced from NIH MedlinePlus
// (https://medlineplus.gov/cardiacrehabilitation.html) on 2026-05-05.
// MedicalEnumeration is abstract; this example shows a concrete medical enum
// subtype (MedicalSpecialty) carrying the value, with the abstract parent
// referenced in additionalType for documentation.
// Not for use in client deliverables. Generate your own markup using your
// content in the Generator.
{
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": "Cardiac Rehabilitation Program Overview",
  "specialty": {
    "@type": "MedicalSpecialty",
    "additionalType": "https://schema.org/MedicalEnumeration",
    "name": "Cardiovascular"
  },
  "about": {
    "@type": "MedicalCondition",
    "name": "Coronary artery disease"
  }
}
