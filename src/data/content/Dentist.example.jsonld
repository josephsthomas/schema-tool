{
  "@context": "https://schema.org",
  "@type": "Dentist",
  "name": "General Dentist",
  "description": "A general dentistry practitioner who provides routine examinations and evaluations, diagnostic imaging, preventive care guidance, and specialist referrals for conditions like gum disease, tooth decay, and orthodontic needs.",
  "availableService": [
    {
      "@type": "MedicalProcedure",
      "name": "Routine dental examination",
      "description": "Routine examinations and evaluations."
    },
    {
      "@type": "MedicalProcedure",
      "name": "Dental diagnostic imaging",
      "description": "Diagnostic imaging including dental x-rays and panoramic imaging."
    },
    {
      "@type": "MedicalProcedure",
      "name": "Preventive dental care guidance",
      "description": "Brush teeth twice a day with a fluoride toothpaste and clean between teeth every day with floss or another type of between-the-teeth cleaner."
    }
  ]
}
