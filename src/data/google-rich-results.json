{
  "$schema": "./google-rich-results.schema.json",
  "_comment": "Hand-curated mapping of (typeId, propertyName) -> 'required' | 'recommended' for the schema.org types Google issues rich results for + a few medical-adjacent recommendations. Provenance: developers.google.com/search/docs/appearance/structured-data as of 2026-05-05. Re-review quarterly per plan §4.3.",
  "_lastReviewed": "2026-05-05",
  "annotations": {
    "schema:FAQPage": {
      "mainEntity": "required"
    },
    "schema:HowTo": {
      "name": "required",
      "step": "required",
      "tool": "recommended",
      "supply": "recommended",
      "totalTime": "recommended"
    },
    "schema:ClaimReview": {
      "claimReviewed": "required",
      "datePublished": "required",
      "author": "required",
      "reviewRating": "required",
      "itemReviewed": "required"
    },
    "schema:SpecialAnnouncement": {
      "name": "required",
      "datePosted": "required",
      "expires": "required",
      "category": "recommended",
      "announcementLocation": "recommended"
    },
    "schema:MedicalScholarlyArticle": {
      "headline": "required",
      "datePublished": "required",
      "author": "recommended",
      "publisher": "recommended"
    },
    "schema:MedicalCondition": {
      "name": "recommended",
      "code": "recommended"
    },
    "schema:Drug": {
      "name": "recommended",
      "activeIngredient": "recommended",
      "drugClass": "recommended",
      "code": "recommended"
    }
  }
}
